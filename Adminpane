import React, { useState, useRef, useEffect } from 'react';
import { Plus, X, Upload, Sparkles, Save, Image as ImageIcon } from 'lucide-react';
import { Product } from '../types';
import { AVAILABLE_COLORS } from '../constants';
import { generateProductDescription } from '../services/geminiService';

interface AdminPanelProps {
  products: Product[];
  onAddProduct: (product: Product) => void;
  onUpdateProduct: (product: Product) => void;
  onClose: () => void;
  productToEdit?: Product | null;
}

export const AdminPanel: React.FC<AdminPanelProps> = ({ 
  products, 
  onAddProduct, 
  onUpdateProduct,
  onClose,
  productToEdit 
}) => {
  const [editingProduct, setEditingProduct] = useState<Partial<Product>>({
    colors: [],
    stock: 10 // Default stock
  });
  
  useEffect(() => {
    if (productToEdit) {
      setEditingProduct(productToEdit);
    } else {
      setEditingProduct({ colors: [], stock: 10, category: '' });
    }
  }, [productToEdit]);

  const [customColor, setCustomColor] = useState('');
  const [isAiLoading, setIsAiLoading] = useState(false);
  const fileInputRef = useRef<HTMLInputElement>(null);

  // Extract existing categories for suggestions
  const existingCategories = Array.from(new Set(products.map(p => p.category))).filter(Boolean);

  const handleImageUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => {
        setEditingProduct(prev => ({ ...prev, image: reader.result as string }));
      };
      reader.readAsDataURL(file);
    }
  };

  const handleGenerateDescription = async () => {
    if (!editingProduct.name) return;
    
    setIsAiLoading(true);
    const desc = await generateProductDescription(editingProduct.name, editingProduct.image);
    setEditingProduct(prev => ({ ...prev, description: desc }));
    setIsAiLoading(false);
  };

  const handleSave = () => {
    if (!editingProduct.name || !editingProduct.price || !editingProduct.image || !editingProduct.category) {
      alert("يرجى ملء جميع الحقول الأساسية وتحديد القسم");
      return;
    }

    const newProduct: Product = {
      id: editingProduct.id || Date.now().toString(),
      name: editingProduct.name,
      price: Number(editingProduct.price),
      description: editingProduct.description || '',
      details: editingProduct.details || '',
      image: editingProduct.image,
      colors: editingProduct.colors || [],
      category: editingProduct.category,
      stock: Number(editingProduct.stock) || 0
    };

    if (editingProduct.id) {
      onUpdateProduct(newProduct);
    } else {
      onAddProduct(newProduct);
    }
    
    setEditingProduct({ colors: [], stock: 10 });
  };

  const addColor = (color: string) => {
    const currentColors = editingProduct.colors || [];
    if (!currentColors.includes(color)) {
      setEditingProduct({ ...editingProduct, colors: [...currentColors, color] });
    }
  };

  const removeColor = (color: string) => {
    const currentColors = editingProduct.colors || [];
    setEditingProduct({ ...editingProduct, colors: currentColors.filter(c => c !== color) });
  };

  const handleAddCustomColor = () => {
    if (customColor.trim()) {
      addColor(customColor.trim());
      setCustomColor('');
    }
  };

  return (
    <div className="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4">
      <div className="bg-white w-full max-w-2xl rounded-3xl shadow-2xl max-h-[90vh] overflow-y-auto no-scrollbar">
        <div className="p-6 border-b border-gray-100 flex justify-between items-center sticky top-0 bg-white z-10">
          <h2 className="text-2xl font-bold text-gray-800">
            {editingProduct.id ? 'تعديل منتج' : 'إضافة منتج جديد'}
          </h2>
          <button onClick={onClose} className="p-2 hover:bg-gray-100 rounded-full">
            <X className="w-6 h-6 text-gray-500" />
          </button>
        </div>

        <div className="p-6 space-y-6">
          {/* Image Upload */}
          <div className="flex flex-col items-center justify-center">
            <div 
              onClick={() => fileInputRef.current?.click()}
              className="w-full h-48 border-2 border-dashed border-gray-300 rounded-2xl flex flex-col items-center justify-center cursor-pointer hover:border-rose-400 hover:bg-rose-50 transition overflow-hidden relative"
            >
              {editingProduct.image ? (
                <img src={editingProduct.image} alt="Preview" className="w-full h-full object-contain" />
              ) : (
                <>
                  <Upload className="w-10 h-10 text-gray-400 mb-2" />
                  <p className="text-gray-500 text-sm">اضغط لرفع صورة المنتج</p>
                </>
              )}
              <input 
                type="file" 
                ref={fileInputRef} 
                onChange={handleImageUpload} 
                className="hidden" 
                accept="image/*"
              />
            </div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">اسم المنتج</label>
              <input 
                type="text" 
                value={editingProduct.name || ''}
                onChange={e => setEditingProduct({...editingProduct, name: e.target.value})}
                className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
                placeholder="مثال: شريط ستان أحمر"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">السعر (د.ع)</label>
              <input 
                type="number" 
                value={editingProduct.price || ''}
                onChange={e => setEditingProduct({...editingProduct, price: Number(e.target.value)})}
                className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
                placeholder="5000"
              />
            </div>
            {/* Stock Input */}
             <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">الكمية المتوفرة (المخزون)</label>
              <input 
                type="number" 
                value={editingProduct.stock || ''}
                onChange={e => setEditingProduct({...editingProduct, stock: Number(e.target.value)})}
                className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
                placeholder="مثال: 10"
              />
            </div>
            
            {/* Category with Suggestions */}
            <div className="relative">
              <label className="block text-sm font-medium text-gray-700 mb-1">القسم / التصنيف</label>
              <input 
                type="text" 
                list="category-suggestions"
                value={editingProduct.category || ''}
                onChange={e => setEditingProduct({...editingProduct, category: e.target.value})}
                className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
                placeholder="اكتب اسم القسم (مثلاً: تغليف)"
              />
              <datalist id="category-suggestions">
                {existingCategories.map(cat => (
                  <option key={cat} value={cat} />
                ))}
              </datalist>
               {/* Clickable Chips for quick category selection */}
               <div className="flex flex-wrap gap-2 mt-2">
                 {existingCategories.map(cat => (
                   <button 
                     key={cat}
                     onClick={() => setEditingProduct({...editingProduct, category: cat})}
                     className={`text-xs px-2 py-1 rounded-full border transition ${
                       editingProduct.category === cat 
                         ? 'bg-rose-500 text-white border-rose-500'
                         : 'bg-gray-50 text-gray-600 border-gray-200 hover:border-rose-300'
                     }`}
                   >
                     {cat}
                   </button>
                 ))}
               </div>
            </div>
          </div>

          {/* Additional Details (Manual) */}
           <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">تفاصيل إضافية (اختياري)</label>
              <input 
                type="text"
                value={editingProduct.details || ''}
                onChange={e => setEditingProduct({...editingProduct, details: e.target.value})}
                className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
                placeholder="تفاصيل دقيقة تضيفها بنفسك (المقاسات، المادة...)"
              />
          </div>

          {/* AI Description */}
          <div>
            <div className="flex justify-between items-center mb-1">
              <label className="block text-sm font-medium text-gray-700">الوصف التسويقي (الذكاء الاصطناعي)</label>
              <button 
                onClick={handleGenerateDescription}
                disabled={!editingProduct.name || isAiLoading}
                className="flex items-center gap-1 text-xs bg-rose-100 text-rose-700 px-3 py-1 rounded-full hover:bg-rose-200 disabled:opacity-50 transition"
              >
                {isAiLoading ? (
                  <span className="animate-pulse">جاري الكتابة...</span>
                ) : (
                  <>
                    <Sparkles className="w-3 h-3" />
                    <span>توليد وصف</span>
                  </>
                )}
              </button>
            </div>
            <textarea 
              rows={3}
              value={editingProduct.description || ''}
              onChange={e => setEditingProduct({...editingProduct, description: e.target.value})}
              className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
              placeholder="وصف جذاب للمنتج..."
            />
          </div>

          {/* Color Management */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">إدارة الألوان</label>
            
            <div className="flex flex-wrap gap-2 mb-3 p-3 bg-gray-50 rounded-xl min-h-[50px] items-center border border-gray-100">
              {(editingProduct.colors || []).length === 0 && <span className="text-gray-400 text-sm w-full text-center">لا توجد ألوان محددة</span>}
              {(editingProduct.colors || []).map(color => (
                <span key={color} className="flex items-center gap-1 bg-white border border-gray-200 pl-1 pr-3 py-1 rounded-full text-sm text-gray-800 shadow-sm group">
                  {color}
                  <button onClick={() => removeColor(color)} className="bg-gray-100 text-gray-400 hover:bg-red-500 hover:text-white rounded-full p-0.5 transition">
                    <X size={14}/>
                  </button>
                </span>
              ))}
            </div>

            <div className="flex gap-2 mb-4">
              <input 
                type="text" 
                value={customColor}
                onChange={(e) => setCustomColor(e.target.value)}
                className="flex-1 p-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-rose-500 outline-none"
                placeholder="أضف لون جديد..."
                onKeyDown={(e) => e.key === 'Enter' && handleAddCustomColor()}
              />
              <button 
                onClick={handleAddCustomColor}
                className="bg-gray-900 text-white px-5 py-2 rounded-xl text-sm font-medium hover:bg-gray-800 transition"
              >
                إضافة
              </button>
            </div>

            <div>
              <span className="text-xs text-gray-400 block mb-2 font-bold">اقتراحات سريعة:</span>
              <div className="flex flex-wrap gap-2 max-h-24 overflow-y-auto no-scrollbar">
                {AVAILABLE_COLORS.filter(c => !editingProduct.colors?.includes(c)).map(color => (
                  <button
                    key={color}
                    onClick={() => addColor(color)}
                    className="px-3 py-1 rounded-full text-xs border border-dashed border-gray-300 text-gray-500 hover:border-rose-400 hover:text-rose-600 hover:bg-rose-50 transition"
                  >
                    + {color}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <button 
            onClick={handleSave}
            className="w-full bg-rose-600 text-white py-4 rounded-xl font-bold shadow-lg hover:bg-rose-700 transition flex justify-center items-center gap-2"
          >
            <Save className="w-5 h-5" />
            <span>حفظ التغييرات</span>
          </button>
        </div>
      </div>
    </div>
  );
};
